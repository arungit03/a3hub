
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasUserProfile() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return hasUserProfile()
        ? userDoc().data.role
        : null;
    }

    function userStatus() {
      return hasUserProfile() && ("status" in userDoc().data)
        ? userDoc().data.status
        : "active";
    }

    function isUserActive() {
      return hasUserProfile()
        && !(userStatus() in ["blocked", "pending", "pending_approval"]);
    }

    function isPrivilegedAccountActive() {
      return userRole() != null
        && isUserActive();
    }

    function isStudent() {
      return userRole() == "student";
    }

    function isStaff() {
      return userRole() == "staff" && isPrivilegedAccountActive();
    }

    function isAdmin() {
      return userRole() == "admin" && isPrivilegedAccountActive();
    }

    function isCanteenStaff() {
      return userRole() == "canteen_staff" && isPrivilegedAccountActive();
    }

    function canManageCanteen() {
      return isCanteenStaff() || isAdmin();
    }

    function canUseCanteenOrdering() {
      return isUserActive()
        && userRole() in ["student", "staff", "admin"];
    }

    function authBootstrapExists() {
      return exists(/databases/$(database)/documents/systemSettings/authBootstrap);
    }

    function authBootstrapDoc() {
      return get(/databases/$(database)/documents/systemSettings/authBootstrap);
    }

    function hasActiveBootstrapAdmin() {
      return authBootstrapExists()
        && authBootstrapDoc().data.adminUid is string
        && exists(/databases/$(database)/documents/users/$(authBootstrapDoc().data.adminUid))
        && get(/databases/$(database)/documents/users/$(authBootstrapDoc().data.adminUid)).data.role == "admin";
    }

    function isFirstAdminBootstrapForUser(userId) {
      return isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.role == "admin"
        && !hasActiveBootstrapAdmin();
    }

    function isSelfServiceStudentSignup(userId) {
      return isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.role == "student"
        && (
          !("status" in request.resource.data)
          || request.resource.data.status == "active"
        );
    }

    function isSelfServiceStaffSignup(userId) {
      return isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.role == "staff"
        && request.resource.data.status in ["pending", "pending_approval"];
    }

    function isAssignmentQuestionFolder(folder) {
      return folder is string
        && folder.matches("^a3hub/assignments/[^/]+/question$");
    }

    function uploadedFileDoc(fileId) {
      return get(/databases/$(database)/documents/uploadedFiles/$(fileId));
    }

    function uploadedFileExists(fileId) {
      return exists(/databases/$(database)/documents/uploadedFiles/$(fileId));
    }

    function canReadUploadedFileData(fileData) {
      return isStaff()
        || isAdmin()
        || fileData.createdBy == request.auth.uid
        || (isStudent() && isAssignmentQuestionFolder(fileData.folder));
    }

    function canReadUploadedFileById(fileId) {
      return uploadedFileExists(fileId)
        && canReadUploadedFileData(uploadedFileDoc(fileId).data);
    }

    function isValidMenuItemStatus(status) {
      return status in ["available", "limited", "sold_out", "hidden"];
    }

    function isValidOrderStatus(status) {
      return status in ["placed", "collected", "cancelled"];
    }

    function deriveMenuItemStatus(quantity, visible, status) {
      return (!visible || status == "hidden")
        ? "hidden"
        : quantity <= 0
          ? "sold_out"
          : status == "sold_out"
            ? "sold_out"
            : (status == "limited" || quantity <= 5)
              ? "limited"
              : "available";
    }

    function isValidMenuItemPayload(data) {
      return data.keys().hasOnly([
          "name",
          "description",
          "image",
          "price",
          "category",
          "quantity",
          "status",
          "visible",
          "createdBy",
          "createdAt",
          "updatedAt"
        ])
        && data.name is string
        && data.name.size() > 0
        && data.description is string
        && data.image is string
        && data.price is number
        && data.price >= 0
        && data.category is string
        && data.category.size() > 0
        && data.quantity is int
        && data.quantity >= 0
        && data.visible is bool
        && isValidMenuItemStatus(data.status)
        && data.createdBy is string
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    function isValidCanteenOrderCounterPayload(data) {
      return data.keys().hasOnly([
          "dateKey",
          "lastSequence",
          "lastOrderId",
          "lastOrderUserId",
          "updatedAt"
        ])
        && data.dateKey is string
        && data.dateKey.size() > 0
        && data.lastSequence is int
        && data.lastSequence > 0
        && data.lastOrderId is string
        && data.lastOrderId.size() > 0
        && data.lastOrderUserId is string
        && data.lastOrderUserId.size() > 0
        && data.updatedAt is timestamp;
    }

    function canReadCanteenOrderCounterAfter() {
      return existsAfter(/databases/$(database)/documents/systemSettings/canteenOrderCounter);
    }

    function canteenOrderCounterAfter() {
      return getAfter(/databases/$(database)/documents/systemSettings/canteenOrderCounter).data;
    }

    function isClientCanteenOrderCounterWrite() {
      return canUseCanteenOrdering()
        && isValidCanteenOrderCounterPayload(request.resource.data)
        && request.resource.data.lastOrderUserId == request.auth.uid;
    }

    function isClientPlacedOrderCreate(orderId) {
      return canUseCanteenOrdering()
        && isValidOrderPayload(request.resource.data)
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == "placed"
        && canReadCanteenOrderCounterAfter()
        && canteenOrderCounterAfter().dateKey == request.resource.data.createdDateKey
        && canteenOrderCounterAfter().lastOrderUserId == request.auth.uid
        && canteenOrderCounterAfter().lastOrderId == orderId;
    }

    function isClientInventoryAdjustment() {
      return canUseCanteenOrdering()
        && resource.data.visible == true
        && isValidMenuItemPayload(request.resource.data)
        && request.resource.data.name == resource.data.name
        && request.resource.data.description == resource.data.description
        && request.resource.data.image == resource.data.image
        && request.resource.data.price == resource.data.price
        && request.resource.data.category == resource.data.category
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.visible == resource.data.visible
        && request.resource.data.quantity is int
        && request.resource.data.quantity >= 0
        && request.resource.data.quantity <= resource.data.quantity
        && request.resource.data.status == deriveMenuItemStatus(
          request.resource.data.quantity,
          request.resource.data.visible,
          resource.data.status
        )
        && canReadCanteenOrderCounterAfter()
        && canteenOrderCounterAfter().lastOrderUserId == request.auth.uid
        && existsAfter(
          /databases/$(database)/documents/orders/$(canteenOrderCounterAfter().lastOrderId)
        )
        && getAfter(
          /databases/$(database)/documents/orders/$(canteenOrderCounterAfter().lastOrderId)
        ).data.userId == request.auth.uid;
    }

    function isValidOrderPayload(data) {
      return data.keys().hasOnly([
          "userId",
          "userName",
          "userEmail",
          "items",
          "totalAmount",
          "itemCount",
          "status",
          "tokenNumber",
          "createdDateKey",
          "createdAt",
          "updatedAt"
        ])
        && data.userId is string
        && data.userId.size() > 0
        && data.userName is string
        && data.userName.size() > 0
        && data.userEmail is string
        && data.items is list
        && data.items.size() > 0
        && data.totalAmount is number
        && data.totalAmount >= 0
        && data.itemCount is int
        && data.itemCount > 0
        && isValidOrderStatus(data.status)
        && data.tokenNumber is string
        && data.tokenNumber.size() > 0
        && data.createdDateKey is string
        && data.createdDateKey.size() > 0
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isStaff() || isAdmin());
      allow create: if (
          isAdmin()
          && request.resource.data.role in ["student", "staff", "parent", "admin", "canteen_staff"]
        )
        || isSelfServiceStudentSignup(userId)
        || isSelfServiceStaffSignup(userId)
        || isFirstAdminBootstrapForUser(userId);
      allow update: if isAdmin() || (
          isSignedIn()
          && request.auth.uid == userId
          && request.resource.data.role == resource.data.role
          && request.resource.data.status == resource.data.status
        );
      allow delete: if isAdmin();

      match /notifications/{notificationId} {
        allow read: if request.auth != null && (request.auth.uid == userId || isStaff() || isAdmin());
        allow create: if request.auth != null
          && (isStaff() || isAdmin() || request.auth.uid == userId)
          && request.resource.data.recipientId == userId
          && request.resource.data.type is string
          && request.resource.data.title is string
          && request.resource.data.expiresAt is timestamp;
        allow update: if isStaff() || isAdmin() || (
          request.auth != null
          && request.auth.uid == userId
          && request.resource.data.recipientId == resource.data.recipientId
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "read",
            "readAt"
          ])
        );
        allow delete: if isStaff() || isAdmin() || (request.auth != null && request.auth.uid == userId);
      }

      match /todoItems/{todoId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.keys().hasOnly([
            "text",
            "createdAt",
            "createdBy"
          ])
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.createdAt is timestamp
          && request.resource.data.createdBy == request.auth.uid;
        allow update: if false;
        allow delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /systemSettings/{settingId} {
      allow read: if (
          settingId != "canteenOrderCounter"
          && isSignedIn()
        ) || (
          settingId == "canteenOrderCounter"
          && (canManageCanteen() || canUseCanteenOrdering())
        );
      allow create: if isAdmin() || (
        settingId == "authBootstrap"
        && isSignedIn()
        && !hasActiveBootstrapAdmin()
        && existsAfter(/databases/$(database)/documents/users/$(request.auth.uid))
        && getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
        && request.resource.data.adminUid is string
        && request.resource.data.adminUid == request.auth.uid
      ) || (
        settingId == "canteenOrderCounter"
        && isClientCanteenOrderCounterWrite()
      );
      allow update: if isAdmin() || (
        settingId == "authBootstrap"
        && isSignedIn()
        && !hasActiveBootstrapAdmin()
        && existsAfter(/databases/$(database)/documents/users/$(request.auth.uid))
        && getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
        && request.resource.data.adminUid is string
        && request.resource.data.adminUid == request.auth.uid
      ) || (
        settingId == "canteenOrderCounter"
        && isClientCanteenOrderCounterWrite()
      );
      allow delete: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow read, write: if isAdmin();
    }

    match /departments/{departmentId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /subjects/{subjectId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /classes/{classId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /notices/{noticeId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isStaff() || isAdmin();
    }

    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /eventSubmissions/{submissionId} {
      allow read: if isSignedIn()
        && (isStaff() || isAdmin() || resource.data.studentId == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.studentId == request.auth.uid
        && request.resource.data.eventId is string
        && request.resource.data.eventId.size() > 0
        && submissionId == request.resource.data.eventId + "_" + request.auth.uid;
      allow update: if isAdmin()
        || (
          isSignedIn()
          && resource.data.studentId == request.auth.uid
          && request.resource.data.studentId == resource.data.studentId
          && request.resource.data.eventId == resource.data.eventId
          && submissionId == resource.data.eventId + "_" + request.auth.uid
        );
      allow delete: if isAdmin();
    }

    match /schedules/{scheduleId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isStaff() || isAdmin();
    }

    match /todaysSchedules/{scheduleId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isStaff() || isAdmin();
    }

    match /assignments/{assignmentId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isStaff() || isAdmin();
    }

    match /assignmentSubmissions/{submissionId} {
      allow read: if isSignedIn()
        && (isStaff() || isAdmin() || resource.data.studentId == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.studentId == request.auth.uid
        && request.resource.data.assignmentId is string
        && request.resource.data.assignmentId.size() > 0
        && submissionId == request.resource.data.assignmentId + "_" + request.auth.uid
        && request.resource.data.file is map
        && request.resource.data.file.url is string
        && request.resource.data.file.url.size() > 0;
      allow update: if isSignedIn() && (
        isStaff() || isAdmin() || (
          resource.data.studentId == request.auth.uid
          && request.resource.data.studentId == resource.data.studentId
          && request.resource.data.assignmentId == resource.data.assignmentId
          && submissionId == resource.data.assignmentId + "_" + request.auth.uid
          && request.resource.data.file is map
          && request.resource.data.file.url is string
          && request.resource.data.file.url.size() > 0
        )
      );
      allow delete: if isStaff() || isAdmin();
    }

    match /uploadedFiles/{fileId} {
      allow read: if isSignedIn()
        && canReadUploadedFileData(resource.data);
      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly([
          "name",
          "mimeType",
          "size",
          "folder",
          "provider",
          "chunkCount",
          "chunkSizeBytes",
          "createdAt",
          "createdBy"
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.mimeType is string
        && request.resource.data.size is int
        && request.resource.data.size > 0
        && request.resource.data.folder is string
        && request.resource.data.folder.size() > 0
        && request.resource.data.provider == "firestore-chunks"
        && request.resource.data.chunkCount is int
        && request.resource.data.chunkCount > 0
        && request.resource.data.chunkSizeBytes is int
        && request.resource.data.chunkSizeBytes > 0
        && request.resource.data.createdAt is timestamp
        && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if isStaff()
        || isAdmin()
        || (isSignedIn() && resource.data.createdBy == request.auth.uid);

      match /chunks/{chunkId} {
        allow read: if isSignedIn() && canReadUploadedFileById(fileId);
        allow create: if isSignedIn()
          && uploadedFileExists(fileId)
          && uploadedFileDoc(fileId).data.createdBy == request.auth.uid
          && request.resource.data.keys().hasOnly([
            "index",
            "data"
          ])
          && request.resource.data.index is int
          && request.resource.data.index >= 0
          && request.resource.data.data is string
          && request.resource.data.data.size() > 0
          && request.resource.data.data.size() <= 320000
          && chunkId.matches("^[0-9]{6}$");
        allow update, delete: if false;
      }
    }

    match /examSchedules/{examId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isStaff() || isAdmin();
    }

    match /tests/{testId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isStaff() || isAdmin();
    }

    match /testResults/{resultId} {
      allow read: if isSignedIn()
        && (isStaff() || isAdmin() || resource.data.studentId == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.studentId == request.auth.uid
        && request.resource.data.testId is string
        && request.resource.data.testId.size() > 0
        && resultId == request.resource.data.testId + "_" + request.auth.uid
        && !exists(/databases/$(database)/documents/testResults/$(resultId));
      allow update: if isStaff() || isAdmin();
      allow delete: if isStaff() || isAdmin();
    }

    match /leaveRequests/{requestId} {
      allow read: if isSignedIn()
        && (isStaff() || isAdmin() || resource.data.studentId == request.auth.uid);
      allow create: if isSignedIn()
        && userRole() != "staff"
        && request.resource.data.studentId == request.auth.uid
        && request.resource.data.requestDate is string
        && request.resource.data.expiresAt is timestamp
        && requestId == request.auth.uid + "_" + request.resource.data.requestDate
        && !exists(/databases/$(database)/documents/leaveRequests/$(requestId));
      allow update, delete: if isStaff() || isAdmin();
    }

    match /attendancePeriods/{periodId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isStaff() || isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isStaff() || isAdmin();
    }

    match /attendanceAbsenceReasons/{replyId} {
      allow read: if isSignedIn()
        && (isStaff() || isAdmin() || resource.data.studentId == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.studentId == request.auth.uid
        && request.resource.data.date is string
        && request.resource.data.reason is string
        && request.resource.data.reason.size() > 0
        && !exists(/databases/$(database)/documents/attendanceAbsenceReasons/$(replyId));
      allow update: if isStaff() || isAdmin();
      allow delete: if isStaff() || isAdmin();
    }

    match /modules/{moduleId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isStaff() || isAdmin();
    }

    match /books/{bookId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isStaff() || isAdmin();

      match /units/{unitId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isStaff() || isAdmin();
      }
    }

    match /academicCalendarEntries/{entryId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isStaff() || isAdmin();
    }

    match /fees/{feeId} {
      allow read: if isSignedIn()
        && (isStaff() || isAdmin() || resource.data.studentId == request.auth.uid);
      allow create, update, delete: if isStaff() || isAdmin();
    }

    match /internalMarks/{recordId} {
      allow read: if isSignedIn()
        && (isStaff() || isAdmin() || resource.data.studentId == request.auth.uid);
      allow create, update, delete: if isStaff() || isAdmin();
    }

    match /menuItems/{itemId} {
      allow read: if canManageCanteen()
        || (canUseCanteenOrdering() && resource.data.visible == true);
      allow create: if canManageCanteen()
        && isValidMenuItemPayload(request.resource.data)
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if (canManageCanteen()
        && isValidMenuItemPayload(request.resource.data)
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt)
        || isClientInventoryAdjustment();
      allow delete: if canManageCanteen();
    }

    match /orders/{orderId} {
      allow read: if canManageCanteen()
        || (canUseCanteenOrdering() && resource.data.userId == request.auth.uid);
      allow create: if (canManageCanteen()
        && isValidOrderPayload(request.resource.data))
        || isClientPlacedOrderCreate(orderId);
      allow update: if canManageCanteen()
        && isValidOrderPayload(request.resource.data)
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.userName == resource.data.userName
        && request.resource.data.userEmail == resource.data.userEmail
        && request.resource.data.items == resource.data.items
        && request.resource.data.totalAmount == resource.data.totalAmount
        && request.resource.data.itemCount == resource.data.itemCount
        && request.resource.data.tokenNumber == resource.data.tokenNumber
        && request.resource.data.createdDateKey == resource.data.createdDateKey
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin();
    }

    match /dailyPythonChallenges/{challengeId} {
      allow read: if isStudent() && request.auth.uid == challengeId;
      allow create, update: if isStudent()
        && request.auth.uid == challengeId
        && request.resource.data.generatedAtKey is string
        && request.resource.data.generatedBy == request.auth.uid
        && request.resource.data.createdAt is timestamp
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.expiresAt > request.resource.data.createdAt
        && request.resource.data.challenges is list
        && request.resource.data.challenges.size() == 5;
      allow delete: if isStudent() && request.auth.uid == challengeId;
    }

    match /dailyPythonProgress/{studentId} {
      allow read: if isStudent() && request.auth.uid == studentId;
      allow create, update: if isStudent()
        && request.auth.uid == studentId
        && request.resource.data.studentId == request.auth.uid
        && request.resource.data.currentDayKey is string
        && request.resource.data.solvedChallengeIds is list
        && request.resource.data.solvedCount is int
        && request.resource.data.totalSolvedChallenges is int
        && request.resource.data.daysParticipated is int
        && request.resource.data.dailyStreak is int
        && request.resource.data.bestStreak is int
        && request.resource.data.lastSolvedDayKey is string
        && request.resource.data.lastSolvedAt is timestamp
        && request.resource.data.updatedAt is timestamp;
      allow delete: if false;
    }

    match /learningCourses/{courseId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /learningTopics/{topicId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /learningQuizzes/{topicId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /learningProblems/{topicId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /userLearningProgress/{userId} {
      allow read: if isSignedIn()
        && (request.auth.uid == userId || isStaff() || isAdmin());
      allow create, update: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.topicStates is map
        && request.resource.data.courseProgress is map
        && request.resource.data.overallProgress is number
        && request.resource.data.completedLessonsCount is int
        && request.resource.data.passedQuizzesCount is int
        && request.resource.data.solvedProblemsCount is int
        && request.resource.data.lastTopicId is string
        && request.resource.data.recommendedTopicId is string
        && (
          !("recentTopicIds" in request.resource.data)
          || request.resource.data.recentTopicIds is list
        )
        && request.resource.data.updatedAt is timestamp;
      allow delete: if false;
    }

    match /savedHtmlSnippets/{snippetId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.code is string;
      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }

    match /editorHistory/{userId} {
      allow read: if isSignedIn()
        && (request.auth.uid == userId || isAdmin());
      allow create, update: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.lastSnippetId is string
        && request.resource.data.lastExampleId is string
        && request.resource.data.recentExampleIds is list
        && request.resource.data.updatedAt is timestamp;
      allow delete: if false;
    }

    match /practiceEditorProgress/{progressId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, update: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.id is string
        && request.resource.data.topicId is string
        && request.resource.data.problemId is string
        && request.resource.data.snippetId is string
        && request.resource.data.completed is bool
        && request.resource.data.updatedAt is timestamp;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
