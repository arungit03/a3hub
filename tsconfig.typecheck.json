    "src/hooks/useToast.js",
    "src/lib/chunkLoadRecovery.js",
    "src/lib/cloudinaryUpload.js",
    "src/lib/codeChallengeProgress.js",
    "src/lib/codeLearningChallenges.js",
    "src/lib/codingTools.js",
    "src/lib/firebase.js",
    "src/lib/nativeCodeRunner.js",
    "src/lib/qr.js",
    "src/lib/scheduleDate.js",
    "src/state/toast-context.js",
    "scripts/project-structure.mjs"
  ]
